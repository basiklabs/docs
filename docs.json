{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Tracelit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "customCss": "/style.css",
  "navigation": {
    "tabs": [
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              {
                "group": "Framework installation",
                "pages": [
                  "installation/react",
                  "installation/vue",
                  "installation/angular",
                  "installation/script-tag",
                  "installation/svelte",
                  "installation/nextjs-app-router",
                  "installation/nextjs-pages-router"
                ]
              }
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/session-replay",
              "features/feature-tagging",
              "features/error-tracking",
              "features/heatmaps",
              "features/live-visitors"
            ]
          },
          {
            "group": "Tracking Users",
            "pages": [
              "tracking/identify-users",
              "tracking/privacy-consent"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/reference"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ],
    "global": {}
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hey@tracelit.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to dashboard",
      "href": "https://tracelit.io/app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/tracelitai",
      "twitter": "https://x.com/tracelitai"
    }
  }
}